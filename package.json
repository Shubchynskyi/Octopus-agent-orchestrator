{
  "name": "octopus-agent-orchestrator",
  "version": "2.4.2",
  "description": "Bootstrap package for deploying the Octopus Agent Orchestrator bundle into a workspace.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shubchynskyi/Octopus-agent-orchestrator.git"
  },
  "homepage": "https://github.com/Shubchynskyi/Octopus-agent-orchestrator#readme",
  "bugs": {
    "url": "https://github.com/Shubchynskyi/Octopus-agent-orchestrator/issues"
  },
  "license": "Apache-2.0",
  "type": "commonjs",
  "bin": {
    "octopus": "bin/octopus.js",
    "oao": "bin/octopus.js",
    "octopus-agent-orchestrator": "bin/octopus.js"
  },
  "scripts": {
    "build:scripts": "node scripts/node-foundation/build-scripts.cjs build.js sync-repo-cli",
    "build": "node scripts/node-foundation/build-scripts.cjs build.js publish-runtime",
    "build:publish-runtime": "node scripts/node-foundation/build-scripts.cjs build.js publish-runtime",
    "build:node-foundation": "node scripts/node-foundation/build-scripts.cjs build.js node-foundation",
    "test": "node scripts/node-foundation/build-scripts.cjs test.js",
    "test:node-foundation": "node scripts/node-foundation/build-scripts.cjs test.js",
    "validate:version-parity": "node scripts/node-foundation/build-scripts.cjs validate-release.js",
    "validate:release": "npm run validate:version-parity && npm run build && npm test && node --test .node-build/tests/node/packaging/pack-smoke.test.js",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.node-foundation.json",
    "prepack": "npm run build:publish-runtime"
  },
  "files": [
    ".gitattributes",
    "bin",
    "dist",
    "src",
    "tsconfig.json",
    "tsconfig.node-foundation.json",
    "template",
    "AGENT_INIT_PROMPT.md",
    "CHANGELOG.md",
    "HOW_TO.md",
    "LICENSE",
    "MANIFEST.md",
    "README.md",
    "VERSION"
  ],
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "agents",
    "bootstrap",
    "copilot",
    "orchestrator"
  ]
}
