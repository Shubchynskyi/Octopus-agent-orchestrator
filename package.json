{
  "name": "octopus-agent-orchestrator",
  "version": "1.0.8",
  "description": "Bootstrap package for deploying the Octopus Agent Orchestrator bundle into a workspace.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "octopus": "bin/octopus.js",
    "oao": "bin/octopus.js",
    "octopus-agent-orchestrator": "bin/octopus.js"
  },
  "scripts": {
    "build:node-foundation": "node --input-type=commonjs --eval \"require.extensions['.ts']=require.extensions['.js'];require(process.argv[1]).runNodeFoundationBuild()\" ./scripts/node-foundation/build.ts",
    "test:node-foundation": "node --input-type=commonjs --eval \"require.extensions['.ts']=require.extensions['.js'];require(process.argv[1]).runNodeFoundationTests()\" ./scripts/node-foundation/test.ts"
  },
  "files": [
    ".gitattributes",
    "bin",
    "scripts",
    "src",
    "tsconfig.node-foundation.json",
    "template",
    "AGENT_INIT_PROMPT.md",
    "CHANGELOG.md",
    "HOW_TO.md",
    "LICENSE",
    "MANIFEST.md",
    "README.md",
    "VERSION",
    "!**/__pycache__",
    "!**/.pytest_cache",
    "!**/*.pyc",
    "!**/*.pyo",
    "!**/*.pyd"
  ],
  "devDependencies": {
    "@types/node": "^22.14.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agents",
    "bootstrap",
    "copilot",
    "orchestrator"
  ]
}
