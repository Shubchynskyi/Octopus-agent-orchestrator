{
  "version": 2,
  "profiles": {
    "p_compile_maven": {
      "description": "Maven compile — fixture profile for parity tests.",
      "operations": [
        { "type": "strip_ansi" },
        { "type": "truncate_line_length", "max_chars": 100 }
      ],
      "parser": {
        "type": "compile_failure_summary",
        "strategy": "maven",
        "max_matches": 5,
        "tail_count": 2
      }
    },
    "p_compile_ctx": {
      "description": "Compile profile that resolves strategy and tail_count from context.",
      "operations": [{ "type": "strip_ansi" }],
      "parser": {
        "type": "compile_failure_summary",
        "strategy": { "context_key": "command_filter_strategy" },
        "max_matches": 5,
        "tail_count": { "context_key": "fail_tail_lines" }
      }
    },
    "p_test_failure": {
      "description": "Test failure — fixture profile for parity tests.",
      "operations": [
        { "type": "strip_ansi" },
        { "type": "truncate_line_length", "max_chars": 100 }
      ],
      "parser": {
        "type": "test_failure_summary",
        "max_matches": 5,
        "tail_count": 2
      }
    },
    "p_lint_failure": {
      "description": "Lint failure — fixture profile for parity tests.",
      "operations": [
        { "type": "strip_ansi" },
        { "type": "truncate_line_length", "max_chars": 100 }
      ],
      "parser": {
        "type": "lint_failure_summary",
        "max_matches": 5,
        "tail_count": 2
      }
    },
    "p_review_fail": {
      "description": "Review gate failure — fixture profile for parity tests.",
      "operations": [
        { "type": "strip_ansi" },
        { "type": "truncate_line_length", "max_chars": 100 }
      ],
      "parser": {
        "type": "review_gate_summary",
        "max_lines": 3
      }
    },
    "p_review_success": {
      "description": "Review gate success — max_total_lines pre-truncation then parser.",
      "operations": [
        { "type": "strip_ansi" },
        { "type": "max_total_lines", "max_lines": 2, "strategy": "head" }
      ],
      "parser": {
        "type": "review_gate_summary",
        "max_lines": 4
      }
    },
    "p_emit_empty": {
      "description": "Profile that drops all lines and emits a fixed string.",
      "operations": [
        { "type": "drop_lines_matching", "pattern": ".*" }
      ],
      "emit_when_empty": "PASS: output suppressed"
    },
    "p_legacy_ops": {
      "description": "Profile with legacy single-object operations (schema violation). Python falls back; PowerShell is tolerant.",
      "operations": { "type": "strip_ansi" }
    }
  }
}
