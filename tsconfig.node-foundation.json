{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "strict": false,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "tests/node/**/*.ts",
    "scripts/node-foundation/**/*.ts"
  ]
}
